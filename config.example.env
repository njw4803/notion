# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxx

# 경력기술서 루트 페이지 ID
# https://jiwon1226.notion.site/4-c1c2a9363bd14cb885746d2de4eb1b51
NOTION_RESUME_PAGE_ID=c1c2a9363bd1-4cb8-8574-6d2de4eb1b51

# Projects 데이터베이스 ID (Work Experience / 프로젝트 표) — 본인 Notion 값으로 교체
# 확인: cd notion && python3 sync_to_notion.py --discover
NOTION_PROJECTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DB 컬럼 이름 (Notion Projects DB 와 일치)
NOTION_PROP_PROJECT_NAME=프로젝트 명
NOTION_PROP_PERIOD=진행 기간
NOTION_PROP_PERIOD_TYPE=date
NOTION_PROP_ROLE=역할
NOTION_PROP_ROLE_TYPE=multi_select
NOTION_PROP_TEAM=Team Members
NOTION_PROP_AFFILIATION=소속
NOTION_PROP_ONE_LINER=한 줄 소개
NOTION_PROP_SKILLS=Skills

# 1: notion/content/ 변경 없어도 매 git commit마다 Notion 동기화(post-commit 훅). 0: MD 변경이 커밋에 포함될 때만 동기화
NOTION_SYNC_EVERY_COMMIT=0

# update_detail_on_tag.sh — 본인 커밋만 반영 (주제별 압축)
# 기본: git config user.email (커밋 author 와 다를 때만 아래 override)
# NOTION_GIT_AUTHOR_EMAIL=
# NOTION_GIT_AUTHOR_NAME=
# NOTION_SYNCBOX_PROJECT_MD=content/Projects/(주)도로시 Solution SyncBox.md
